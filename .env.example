# === Obrigatorias ===

# Token do bot do Telegram (obtido via @BotFather)
TELEGRAM_TOKEN=seu_token_aqui

# ID do chat/grupo do Telegram onde os alertas serao enviados
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# Chave da API de esports (ex: pandascore, lolesports)
ESPORTS_API_KEY=sua_chave_aqui

# === Opcionais (valores padrao entre parenteses) ===

# Nome do time a ser monitorado (loud)
TEAM_NAME=loud

# Intervalo em minutos entre cada verificacao (2)
CHECK_INTERVAL_MINUTES=2

# Tempo em minutos antes da partida para disparar o alerta (5)
ALERT_THRESHOLD_MINUTES=5
